# Evano Studio desktop — optional renderer build-time config.
# Copy to `.env` to override defaults. Vite only exposes vars prefixed VITE_.

# Base URL of the local Agent Engine backend (no trailing slash).
# Defaults to http://127.0.0.1:8765 when unset.
# VITE_EVANO_BACKEND_URL=http://127.0.0.1:8765
