# Evano Studio — Agent Engine configuration
#
# Copy this file to `.env` and adjust as needed. Every variable is optional and
# has a safe local default. All variables are prefixed with EVANO_.
#
# IMPORTANT: no secrets are required to run this backend. Do not commit a real
# `.env` file (it is git-ignored). Never put secrets in logs or in source.

# Environment: development | production
# EVANO_ENVIRONMENT=development

# Network binding — local only by design. Do not expose to the network.
# EVANO_HOST=127.0.0.1
# EVANO_PORT=8765

# Logging level: DEBUG | INFO | WARNING | ERROR
# EVANO_LOG_LEVEL=INFO

# CORS is restricted to localhost / 127.0.0.1 (any port) by default so only the
# local Evano Studio desktop app can call it. Override only if you know why.
# EVANO_CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$

# Local app data directory. The SQLite database is stored at
# <EVANO_DATA_DIR>/sqlite/evano.db. Defaults to ~/.evano-studio.
# For monorepo development you may point this at the repo's data folder, e.g.:
# EVANO_DATA_DIR=../../data
# EVANO_DATA_DIR=/Users/you/.evano-studio

# Optional: override the full database URL (advanced). When set, it takes
# precedence over EVANO_DATA_DIR. Example in-memory DB used by tests:
# EVANO_DATABASE_URL=sqlite://

# Ollama (local AI runtime). Local by default. The backend never assumes Ollama
# is installed or that any model exists.
# EVANO_OLLAMA_BASE_URL=http://localhost:11434
# EVANO_OLLAMA_RECOMMENDED_MODEL=gemma4
# EVANO_OLLAMA_TIMEOUT_SECONDS=4.0
# EVANO_OLLAMA_CHAT_TIMEOUT_SECONDS=30.0

# Knowledge base / RAG (ChromaDB local only — never Chroma Cloud).
# Embedding provider: "default" (local MiniLM via onnxruntime; free; downloads a
# ~80MB model the first time), "ollama" (needs an embedding model pulled, e.g.
# nomic-embed-text), or "hash" (pure-python, zero-download fallback; lower quality).
# EVANO_EMBEDDING_PROVIDER=default
# EVANO_EMBEDDING_MODEL=nomic-embed-text
# EVANO_CHROMA_COLLECTION=evano_knowledge
# EVANO_CHUNK_SIZE=1000
# EVANO_CHUNK_OVERLAP=150
# EVANO_RAG_TOP_K=4
# EVANO_RAG_MAX_CONTEXT_CHARS=4000
